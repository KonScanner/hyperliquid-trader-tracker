# Keep the build context small — the Dockerfile only needs src/, pyproject.toml,
# uv.lock and README.md; everything below would just be sent to the daemon.
.git
.venv
.ruff_cache
.pytest_cache
.mypy_cache
__pycache__/
*.py[codz]

# Local state / secrets — never bake these into an image.
.env
*.db
*.db-wal
*.db-shm
tracker.db*

# Repo scaffolding not needed at build time.
docs/
tests/
