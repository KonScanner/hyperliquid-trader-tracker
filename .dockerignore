# Keep the build context small — the Python image needs src/, pyproject.toml, uv.lock
# and README.md; the Rust image needs src/, Cargo.toml and Cargo.lock. Everything below
# would just be sent to the daemon.
.git
.venv
.ruff_cache
.pytest_cache
.mypy_cache
__pycache__/
*.py[codz]

# Rust build output (cargo rebuilds inside the image's cache mount).
target/

# Local state / secrets — never bake these into an image.
.env
*.db
*.db-wal
*.db-shm
tracker.db*

# Repo scaffolding not needed at build time.
docs/
tests/
